# ===================
# VidkNot 环境配置
# ===================
# 复制此文件为 .env 并填入实际值

# ===== 必填 =====
# SiliconFlow API Key（转录用）
# 注册地址: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=

# LLM API Key（生成笔记用）
OPENAI_API_KEY=

# ===== 语雀（可选）=====
# 注册地址: https://www.yuque.com
YUQUE_TOKEN=
YUQUE_LOGIN=

# ===== 飞书（可选）=====
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ===== Obsidian（可选）=====
OBSIDIAN_VAULT_PATH=./obsidian-vault

# ===== Notion（可选）=====
# 注册地址: https://www.notion.so/
# 创建集成: https://www.notion.so/my-integrations
NOTION_TOKEN=
NOTION_PAGE_ID=
